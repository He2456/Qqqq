<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>مستخرج الأفلام الشامل</title>
    <style>
        body { font-family: sans-serif; background: #121212; color: #fff; padding: 20px; text-align: center; }
        button { background: #E50914; color: white; border: none; padding: 15px 30px; font-size: 18px; cursor: pointer; border-radius: 5px; margin: 20px; }
        textarea { width: 100%; height: 400px; background: #222; color: #fff; padding: 10px; border-radius: 5px; font-family: monospace; }
    </style>
</head>
<body>

    <h2>مستخرج الأفلام الكاملة بصيغة M3U</h2>
    <p>اضغط على الزر بالأسفل لجلب الـ 500 فيلم كاملة من السيرفر مباشرة لرفعه للوحتك</p>
    
    <button onclick="fetchMovies()">جلب كافة الأفلام الآن</button>
    
    <br>
    <textarea id="result" placeholder="الرابط الشامل سيظهر هنا..."></textarea>

    <script>
    async function fetchMovies() {
        const txt = document.getElementById('result');
        txt.value = "جاري جلب الأفلام كاملة، انتظر ثواني...";
        
        // الرابط الشامل لبيانات السيرفر
        const url = "http://185.191.126.127:8080/player_api.php?username=357643467990765&password=Ofgo3yz8CH&action=get_vod_streams";
        
        try {
            // نطلب البيانات عبر بروكسب مجاني لتجنب حظر المتصفح CORS
            const proxyUrl = "https://api.allorigins.win/get?url=" + encodeURIComponent(url);
            const response = await fetch(proxyUrl);
            const data = await response.json();
            const movies = JSON.parse(data.contents);
            
            let m3u = "#EXTM3U\n\n";
            
            movies.forEach(movie => {
                const id = movie.stream_id || movie.id;
                const name = (movie.name || "").trim();
                const logo = movie.stream_icon || movie.logo || "";
                const ext = movie.container_extension || "mp4";
                const group = (movie.category_name || "الأفلام").trim();
                
                // بناء رابط الفيلم المباشر
                const streamUrl = `http://185.191.126.127:8080/movie/357643467990765/Ofgo3yz8CH/${id}.${ext}`;
                
                if(name && id) {
                    m3u += `#EXTINF:-1 tvg-id="${id}" tvg-name="${name}" tvg-logo="${logo}" group-title="${group}",${name}\n`;
                    m3u += `${streamUrl}\n\n`;
                }
            });
            
            txt.value = m3u;
            alert("تم جلب كل الأفلام بنجاح! انسخ النص الآن وضعه في لوحتك.");
            
        } catch (error) {
            txt.value = "حدث خطأ أثناء جلب البيانات. تأكد من اتصالك بالإنترنت.";
            console.error(error);
        }
    }
    </script>

</body>
</html>
